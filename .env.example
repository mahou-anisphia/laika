# Server
PORT=8080

# Email flows — POST /api/v1/noti/email/{flow}
# Each flow maps to its own SMTP config. To add a new flow, add
# SMTP_<FLOW>_* vars below and register the key in internal/config/config.go.

# Flow: corporate
SMTP_CORPORATE_HOST=smtp.example.com
SMTP_CORPORATE_PORT=587
SMTP_CORPORATE_USERNAME=corp@example.com
SMTP_CORPORATE_PASSWORD=your_smtp_password
SMTP_CORPORATE_FROM=noreply@corp.example.com

# Flow: personal
SMTP_PERSONAL_HOST=smtp.gmail.com
SMTP_PERSONAL_PORT=587
SMTP_PERSONAL_USERNAME=you@gmail.com
SMTP_PERSONAL_PASSWORD=your_app_password
SMTP_PERSONAL_FROM=you@gmail.com

# Discord gateway — required.
# Bot needs the Guilds intent only. Grant View Channels, Send Messages,
# Embed Links, Attach Files in each server it should post to.
DISCORD_BOT_TOKEN=your_discord_bot_token

# Per-caller rate limit (token bucket). Caller is keyed by leftmost
# X-Forwarded-For, falling back to the TCP peer.
LAIKA_RATELIMIT_RPM=60
LAIKA_RATELIMIT_BURST=30
